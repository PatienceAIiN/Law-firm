{
  "name": "ai-email-saas",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "python -m uvicorn py_api.main:app --host 0.0.0.0 --port 3001",
    "dev:api": "python -m uvicorn py_api.main:app --host 0.0.0.0 --port 3001 --reload",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "postinstall": "prisma generate",
    "build": "cd frontend && npm install && npm run build && cd .. && npx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "axios": "^1.8.4",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "imapflow": "^1.0.186",
    "mailparser": "^3.7.2",
    "nodemailer": "^8.0.4"
  },
  "devDependencies": {
    "prisma": "^6.8.2"
  }
}
