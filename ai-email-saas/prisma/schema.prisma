generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Email {
  id            String   @id @default(cuid())
  messageId     String   @unique @map("message_id")
  subject       String
  sender        String
  body          String   @db.Text
  category      String?
  providerName  String?  @map("provider_name")
  npi           String?
  confidence    Int?
  actionable    Boolean? @default(false)
  missingDocs   String?  @map("missing_docs") @db.Text
  summary       String?  @db.Text
  status        String   @default("pending")
  routingMode   String?  @map("routing_mode")
  ticketId      String?  @map("ticket_id")
  sendAttempts  Int      @default(0) @map("send_attempts")
  lastError     String?  @map("last_error") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  logs Log[]

  @@map("emails")
}

model Ticket {
  id           String @id @default(cuid())
  providerName String @map("provider_name")
  npi          String

  @@map("tickets")
}

model Log {
  id        String   @id @default(cuid())
  emailId   String?  @map("email_id")
  message   String   @db.Text
  status    String
  createdAt DateTime @default(now()) @map("created_at")

  email Email? @relation(fields: [emailId], references: [id], onDelete: SetNull)

  @@index([emailId])
  @@map("logs")
}
