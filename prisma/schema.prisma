// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Migrations (`prisma db push`, `prisma migrate`) bypass the pooler — the
  // schema engine needs its own connections and PgBouncer in session mode
  // runs out of slots quickly. Point this at the Supabase Direct URL
  // (Project Settings → Database → Connection string → "URI" (5432)).
  directUrl = env("DIRECT_URL")
}

// Models
model AdvocateActivationToken {
  id         String   @id @default(cuid())
  advocateId String
  token      String   @unique
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([advocateId])
  @@map("advocate_activation_tokens")
}

model TestimonialAskToken {
  id          String   @id @default(cuid())
  token       String   @unique
  tenantId    String
  clientName  String
  clientEmail String
  used        Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@map("testimonial_ask_tokens")
}

model WorkspaceOpenOtp {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email])
  @@map("workspace_open_otps")
}

model Payment {
  id                String   @id @default(cuid())
  tenantId          String
  receiptId         String?
  advocateId        String?  // lawyer who issued the parent receipt (null = firm/admin)
  amount            Float
  currency          String   @default("INR")
  method            String   @default("UPI") // UPI | NEFT | CASH | OTHER | RAZORPAY
  status            String   @default("PENDING") // PENDING | IN_PROGRESS | COMPLETED | FAILED | REFUNDED | PARTIALLY_REFUNDED
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  refundId          String?
  refundedAmount    Float    @default(0)
  payerName         String?
  payerEmail        String?
  payerPhone        String?
  notes             String?
  proofUrl          String?       // image proof uploaded by the client (png/jpg/jpeg)
  utr               String?       // bank / UPI transaction reference submitted by the client
  approvedById      String?       // AdminUser.id OR Advocate.id who marked COMPLETED
  approvedByName    String?       // denormalized snapshot of the approver's name
  approvedByRole    String?       // 'admin' | 'lawyer'
  // Codex-branch parallel approval fields — kept for the new
  // /api/payments/[id]/status PATCH endpoint and PaymentLog audit trail.
  verificationRequired Boolean    @default(false)
  statusUpdatedByType  String?
  statusUpdatedById    String?
  statusUpdatedByName  String?
  statusUpdatedAt      DateTime?
  transactionNumber    String?
  screenshotUrl        String?
  failureReason     String?
  paidAt            DateTime?
  refundedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, advocateId])
  @@index([receiptId])
  @@index([razorpayOrderId])
  logs              PaymentLog[]

  @@map("payments")
}

model PaymentLog {
  id          String   @id @default(cuid())
  paymentId   String
  tenantId    String
  actorType   String
  actorId     String?
  actorName   String
  action      String
  fromStatus  String?
  toStatus    String?
  details     String?
  createdAt   DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([tenantId, paymentId])
  @@map("payment_logs")
}

model ClientLoginOtp {
  id        String   @id @default(cuid())
  email     String
  otp       String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("client_login_otps")
}

model ClientUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  googleId  String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("client_users")
}

model DirectThread {
  id           String   @id @default(cuid())
  tenantId     String
  advocateId   String?
  clientEmail  String
  clientName   String?
  subject      String?
  firmNote     String?  // private firm/lawyer note about this client; never sent to client
  lastMessageAt DateTime @default(now())
  createdAt    DateTime @default(now())
  messages     DirectMessage[]

  @@index([tenantId, clientEmail])
  @@index([tenantId, advocateId])
  @@map("direct_threads")
}

model DirectMessage {
  id         String   @id @default(cuid())
  threadId   String
  thread     DirectThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderType String   // 'client' | 'lawyer' | 'admin'
  senderId   String?
  senderName String?
  body       String
  createdAt  DateTime @default(now())

  @@index([threadId, createdAt])
  @@map("direct_messages")
}

model AppSumoCode {
  id          String    @id @default(cuid())
  code        String    @unique
  status      String    @default("AVAILABLE") // AVAILABLE | REDEEMED | REVOKED
  tier        String    @default("LIFETIME")
  redeemedBy  String?   // email of redeemer
  tenantId    String?
  tenantSlug  String?
  redeemedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([status])
  @@map("appsumo_codes")
}

model SignupOtp {
  id        String   @id @default(cuid())
  email     String
  otp       String
  payload   String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email])
  @@map("signup_otps")
}

model Tenant {
  id         String   @id @default(cuid())
  slug       String   @unique
  name       String
  ownerEmail String
  status     String   @default("active")
  // Location for the public Find-Barrister directory.
  state      String?
  city       String?
  locality   String?
  pincode    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([state, city])
  @@index([pincode])

  adminUsers       AdminUser[]
  advocates        Advocate[]
  practiceAreas    PracticeArea[]
  blogPosts        BlogPost[]
  siteSettings     SiteSetting[]
  contactInquiries ContactSubmission[]
  aboutProfile     AboutProfile?

  @@map("tenants")
}

model AdminUser {
  id                    String   @id @default(cuid())
  email                 String
  name                  String
  password              String
  role                  String   @default("admin")
  isPasswordResetNeeded Boolean  @default(false)
  tenantId              String?
  tenant                Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  pushSubscriptions PushSubscription[]

  @@unique([tenantId, email])
  @@map("admin_users")
}

model Advocate {
  id               String    @id @default(cuid())
  email            String
  name             String
  password         String
  title            String
  bio              String?
  profileImage     String?
  phone            String?
  expertise        String?
  education        String?
  barCouncilId     String?
  registrationDate DateTime?
  isActive         Boolean   @default(true)
  // Location surfaced on the Find-Barrister directory.
  state            String?
  city             String?
  locality         String?
  pincode          String?
  tenantId         String?
  tenant           Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  cases             CourtCase[]
  accessLogs        AccessLog[]
  caseNotes         CaseNote[]
  contactInquiries  ContactSubmission[]
  availabilityDays  AvailabilityDay[]
  bookings          ConsultationBooking[]
  pushSubscriptions PushSubscription[]

  @@unique([tenantId, email])
  @@index([state, city, isActive])
  @@map("advocates")
}

model AccessLog {
  id         String    @id @default(cuid())
  advocateId String
  loginTime  DateTime  @default(now())
  logoutTime DateTime?
  ipAddress  String?
  userAgent  String?

  advocate Advocate @relation(fields: [advocateId], references: [id], onDelete: Cascade)

  @@map("access_logs")
}

model CaseNote {
  id         String   @id @default(cuid())
  caseId     String
  advocateId String
  content    String
  isPrivate  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  case     CourtCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  advocate Advocate  @relation(fields: [advocateId], references: [id], onDelete: Cascade)

  @@map("case_notes")
}

model AboutProfile {
  id            String   @id @default(cuid())
  name          String
  title         String
  aboutContent  String
  profileImage  String?
  socialLinks   String?
  officeDetails String?
  tenantId      String?  @unique
  tenant        Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("about_profile")
}

model PracticeArea {
  id          String   @id @default(cuid())
  title       String
  slug        String
  description String
  icon        String?
  content     String?
  image       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, slug])
  @@map("practice_areas")
}

model BlogPost {
  id             String    @id @default(cuid())
  title          String
  slug           String
  excerpt        String?
  content        String
  coverImage     String?
  status         String    @default("DRAFT")
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  tenantId       String?
  tenant         Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([tenantId, slug])
  @@map("blog_posts")
}

model ContactSubmission {
  id          String    @id @default(cuid())
  fullName    String
  email       String
  phone       String?
  subject     String
  message     String
  serviceType String?
  status      String    @default("NEW")
  tenantId    String?
  advocateId  String?
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  advocate    Advocate? @relation(fields: [advocateId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@map("contact_submissions")
}

model AvailabilityDay {
  id         String   @id @default(cuid())
  date       DateTime
  isActive   Boolean  @default(true)
  tenantId   String?
  advocateId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  advocate Advocate?          @relation(fields: [advocateId], references: [id], onDelete: Cascade)
  slots    AvailabilitySlot[]

  @@map("availability_days")
}

model AvailabilitySlot {
  id                String   @id @default(cuid())
  dayId             String
  startTime         DateTime
  endTime           DateTime
  capacity          Int      @default(1)
  bookedCount       Int      @default(0)
  isActive          Boolean  @default(true)
  allowedModes      String? // Comma separated modes: PHYSICAL,GOOGLE_MEET,ZOOM
  manualMeetingLink String?
  physicalAddress   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  day      AvailabilityDay       @relation(fields: [dayId], references: [id], onDelete: Cascade)
  bookings ConsultationBooking[]

  @@map("availability_slots")
}

model ConsultationBooking {
  id          String   @id @default(cuid())
  slotId      String
  name        String
  email       String
  phone       String
  subject     String
  notes       String?
  meetingMode String
  meetingLink String?
  status      String   @default("PENDING")
  tenantId    String?
  advocateId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  slot     AvailabilitySlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  advocate Advocate?        @relation(fields: [advocateId], references: [id], onDelete: SetNull)

  @@map("consultation_bookings")
}

model SiteMetric {
  id        String   @id @default(cuid())
  label     String
  value     String
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_metrics")
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  content   String
  rating    Int      @default(5)
  image     String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  tenantId  String?
  status    String   @default("PUBLISHED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonials")
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faqs")
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

model ChatConversation {
  id        String   @id @default(cuid())
  messages  String // JSON array of {role, content, timestamp}
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chat_conversations")
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  title     String
  bio       String
  image     String?
  expertise String?
  education String?
  email     String?
  phone     String?
  linkedin  String?
  state     String?
  city      String?
  locality  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  tenantId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("team_members")
}

model TestimonialRequest {
  id               String   @id @default(cuid())
  token            String   @unique @default(cuid())
  recipientEmail   String
  recipientName    String
  status           String   @default("PENDING") // PENDING, SUBMITTED, APPROVED, REJECTED
  submittedName    String?
  submittedRole    String?
  submittedContent String?
  submittedRating  Int?
  testimonialId    String? // FK to approved Testimonial id
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("testimonial_requests")
}

model CourtCase {
  id                  String    @id @default(cuid())
  caseNumber          String
  title               String
  caseType            String // Civil, Criminal, Family, Property, Labour, etc.
  status              String    @default("ACTIVE") // ACTIVE, CLOSED, DISPOSED, PENDING, ADJOURNED
  court               String // Court name
  judge               String?
  clientName          String
  clientEmail         String
  clientPhone         String?
  opposingParty       String?
  advocateId          String? // FK to Advocate
  filingDate          DateTime?
  nextHearingDate     DateTime?
  courtAppearanceDate DateTime?
  description         String? // Case summary
  photoUrl            String? // Case cover photo
  emailControl        String    @default("NONE")
  sendReminder        Boolean   @default(true)
  reminderSentOn      DateTime?
  tenantId            String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  advocate  Advocate?      @relation(fields: [advocateId], references: [id], onDelete: SetNull)
  documents CaseDocument[]
  payments  CasePayment[]
  notes     CaseNote[]

  @@map("court_cases")
}

model CaseDocument {
  id         String   @id @default(cuid())
  caseId     String
  name       String
  fileUrl    String // Relative path or URL to uploaded PDF
  fileType   String   @default("application/pdf")
  fileSize   Int?
  uploadedAt DateTime @default(now())

  case CourtCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@map("case_documents")
}

model CasePayment {
  id          String   @id @default(cuid())
  caseId      String
  amount      Float
  currency    String   @default("INR")
  mode        String // CASH, CHEQUE, NEFT, UPI, CARD
  reference   String? // Transaction ref / cheque no
  description String?
  paymentDate DateTime
  receiptSent Boolean  @default(false)
  createdAt   DateTime @default(now())

  case CourtCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@map("case_payments")
}

model PasswordResetOTP {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_reset_otps")
}

model Receipt {
  id            String    @id @default(cuid())
  number        String    @unique
  clientName    String
  clientEmail   String
  advocateId    String?
  createdByName String
  items         String
  currency      String    @default("INR")
  subtotal      Float     @default(0)
  taxRate       Float     @default(0)
  taxAmount     Float     @default(0)
  total         Float     @default(0)
  notes         String?
  // Optional + default keeps reads safe even before the prod migration
  // has added the column on existing tenants.
  paymentMethod String?   @default("OTHER")
  caseId        String?   // optional — link to a CourtCase (filtered per lawyer)
  caseTitle     String?   // denormalized snapshot for the PDF
  caseNumber    String?   // denormalized snapshot for the PDF
  status        String    @default("DRAFT")
  sentAt        DateTime?
  tenantId      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("receipts")
}

model CaseActivity {
  id        String   @id @default(cuid())
  caseId    String
  actorType String // ADVOCATE, ADMIN
  actorName String
  action    String // STATUS_CHANGED, CASE_EDITED, NOTE_ADDED, NOTE_DELETED
  details   String?
  createdAt DateTime @default(now())

  @@index([caseId])
  @@map("case_activities")
}

model CaseTrackOTP {
  id          String   @id @default(cuid())
  caseId      String
  email       String
  otp         String
  accessToken String?
  expiresAt   DateTime
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([caseId])
  @@map("case_track_otps")
}

model CaseReminder {
  id             String    @id @default(cuid())
  caseId         String
  scheduledFor   DateTime
  message        String?
  includeDetails Boolean   @default(true)
  sent           Boolean   @default(false)
  sentAt         DateTime?
  createdBy      String?
  createdAt      DateTime  @default(now())

  @@index([caseId])
  @@index([sent, scheduledFor])
  @@map("case_reminders")
}

// DPDP Act 2023 — Consent records
model DpdpConsent {
  id           String    @id @default(cuid())
  fingerprint  String    @unique // browser fingerprint / cookie id
  consentGiven Boolean   @default(false) // true = accepted, false = denied
  purposes     String? // JSON array of accepted purposes
  ipAddress    String?
  userAgent    String?
  givenAt      DateTime  @default(now())
  revokedAt    DateTime?
  updatedAt    DateTime  @updatedAt

  @@index([fingerprint])
  @@map("dpdp_consents")
}

model PushSubscription {
  id          String   @id @default(cuid())
  endpoint    String   @unique
  p256dh      String
  auth        String
  adminUserId String?
  advocateId  String?
  createdAt   DateTime @default(now())

  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  advocate  Advocate?  @relation(fields: [advocateId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}
