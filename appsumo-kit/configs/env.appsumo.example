# Copy to your production .env after a successful redeem-flow smoke test.
# All values are placeholders — replace before deploy.

# AppSumo redemption gate
# Both flags must be set to 'true' to require a code at signup.
# Leave them unset (or 'false') to keep signup completely free during pre-launch.
# Server-side check (signup action rejects without a valid code):
APPSUMO_REQUIRED=false
# Client-side flag — must match APPSUMO_REQUIRED so the form shows/hides the code field.
# This one MUST start with NEXT_PUBLIC_ to be readable in the browser.
NEXT_PUBLIC_APPSUMO_REQUIRED=false
APPSUMO_REDEMPTION_WINDOW_DAYS=60
APPSUMO_CODE_PREFIX=PATIENCE

# Email — buyers see the welcome credentials, so this MUST work
BREVO_API_KEY=xkeysib-...
BREVO_FROM_EMAIL=hello@patienceai.in
BREVO_FROM_NAME=PatienceAI

# Database (Supabase pooler)
DATABASE_URL=postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5&pool_timeout=20
DIRECT_URL=postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres

# NextAuth
NEXTAUTH_URL=https://patienceai.in
NEXTAUTH_SECRET=change-me

# Super admin allowlist (comma-separated)
SUPER_ADMIN_EMAILS=manini@providerpassport.co

# Media uploads — REQUIRED in production (no FS fallback on Render)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# …or R2…
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# LiveKit video consultations
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-livekit-host

# Redis (optional but recommended)
REDIS_URL=redis://default:...@host:port
